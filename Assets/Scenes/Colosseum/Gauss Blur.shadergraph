{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "418b5afb1e4d49b2834b84b440c9ac6d",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GaussianBlur (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 419.5000305175781,
            "y": 217.00001525878907,
            "width": 228.00003051757813,
            "height": 326.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "28bca76dbf774ac387938daff7ce1483"
        },
        {
            "m_Id": "fde68e925ed84d3697b68359eeaaec26"
        },
        {
            "m_Id": "fb9fcf28591a4ce1afd8e45db6adc879"
        },
        {
            "m_Id": "5fa68aadd56a4d12a83b211fad2fc0b0"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GaussianBlur",
    "m_FunctionSource": "",
    "m_FunctionBody": "float4 col = float4(0.0, 0.0, 0.0, 0.0);\r\n\r\n// 9-Tap Gaussian kernel weights\r\nfloat weights[9] = { 0.05, 0.09, 0.12, 0.15, 0.16, 0.15, 0.12, 0.09, 0.05 };\r\nfloat offsets[9] = { -4.0, -3.0, -2.0, -1.0,  0.0,  1.0,  2.0,  3.0,  4.0 };\r\n\r\n// Horizontal Pass\r\nfor (int i = 0; i < 9; i++) {\r\n    col += Tex.Sample(Tex.samplerstate, UV + float2(offsets[i] * Blur, 0.0)) * weights[i];\r\n}\r\n// Vertical Pass\r\nfor (int j = 0; j < 9; j++) {\r\n    col += Tex.Sample(Tex.samplerstate, UV + float2(0.0, offsets[j] * Blur)) * weights[j];\r\n}\r\n\r\n// Average the two passes\r\nOut = col * 0.5;"
}

